# Telegram Bot Token (Get it from @BotFather)
TG_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Google Gemini API Keys (comma-separated, get them from Google AI Studio)
API_KEYS=YOUR_GEMINI_API_KEY_1,YOUR_GEMINI_API_KEY_2

# Group and Thread Mapping
# Examples: 
# -1001:45 -> works only in thread 45 of group -1001
# -1002    -> works in the entire group -1002
# 12345678 -> works in private messages with user 12345678
# Leave empty to allow the bot to answer anywhere
GROUP_THREAD_MAP=YOUR_CHAT_ID;-YOUR_GROUP_ID:THREAD_ID

# Models to cycle through (comma-separated)
MODEL_FALLBACK_LIST=gemini-3.1-flash-lite-preview,gemini-3-flash-preview,gemini-2.5-flash,gemini-2.5-flash-lite

# Button Texts (Localization)
TRAILER_BTN_TEXT="Trailer on YouTube"
SOURCE_BTN_TEXT="Source"

# System Prompt for Gemini (use \n for line breaks)
SYSTEM_PROMPT="Use Google Search to find the movie/TV show title based on quotes.\n\nINPUT DATA:\n{query}\n\nINSTRUCTIONS:\n1. Find the movie using details: character names, unique phrases, and situations from the subtitles.\n2. YOUR RESPONSE WILL BE INSERTED INTO CODE. ANY TEXT OTHER THAN HTML TAGS WILL BREAK THE SYSTEM.\n3. STRICTLY PROHIBITED: writing \"I found\", \"Here is the result\", or duplicating blocks.\n4. In the description — only a brief plot synopsis without spoilers.\n\nOUTPUT STRICTLY AND ONLY THIS BLOCK:\n<b><u>Title (Year)</u></b>\n<b>Type, Genre:</b> values\n<b>Description:</b> plot synopsis"